#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

#define MAX 1001

typedef struct Edge {
    int to, weight;
    struct Edge* next;
} Edge;

Edge* adj[MAX];
int visited[MAX];

// Min Heap
typedef struct {
    int node, weight;
} HeapNode;

HeapNode heap[100000];
int size = 0;

void swap(int i, int j) {
    HeapNode temp = heap[i];
    heap[i] = heap[j];
    heap[j] = temp;
}

void push(int node, int weight) {
    heap[++size].node = node;
    heap[size].weight = weight;

    int i = size;
    while (i > 1 && heap[i].weight < heap[i / 2].weight) {
        swap(i, i / 2);
        i /= 2;
    }
}

HeapNode pop() {
    HeapNode top = heap[1];
    heap[1] = heap[size--];

    int i = 1;
    while (1) {
        int smallest = i;
        int left = 2 * i;
        int right = 2 * i + 1;

        if (left <= size && heap[left].weight < heap[smallest].weight)
            smallest = left;
        if (right <= size && heap[right].weight < heap[smallest].weight)
            smallest = right;

        if (smallest != i) {
            swap(i, smallest);
            i = smallest;
        } else break;
    }

    return top;
}

// Add edge
void addEdge(int u, int v, int w) {
    Edge* e1 = (Edge*)malloc(sizeof(Edge));
    e1->to = v;
    e1->weight = w;
    e1->next = adj[u];
    adj[u] = e1;

    Edge* e2 = (Edge*)malloc(sizeof(Edge));
    e2->to = u;
    e2->weight = w;
    e2->next = adj[v];
    adj[v] = e2;
}

int prim(int n) {
    int total = 0;

    push(1, 0); // start from node 1

    while (size > 0) {
        HeapNode curr = pop();
        int u = curr.node;

        if (visited[u]) continue;

        visited[u] = 1;
        total += curr.weight;

        Edge* temp = adj[u];
        while (temp) {
            if (!visited[temp->to]) {
                push(temp->to, temp->weight);
            }
            temp = temp->next;
        }
    }

    return total;
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    for (int i = 0; i < m; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        addEdge(u, v, w);
    }

    int result = prim(n);
    printf("%d\n", result);

    return 0;
}
