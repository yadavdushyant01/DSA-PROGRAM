#include <stdio.h>

// Lower Bound: first index where nums[i] >= x
int lowerBound(int nums[], int n, int x) {
    int left = 0, right = n - 1;
    int ans = n;  // default if not found

    while (left <= right) {
        int mid = left + (right - left) / 2;

        if (nums[mid] >= x) {
            ans = mid;
            right = mid - 1;  // search left side
        } else {
            left = mid + 1;
        }
    }

    return ans;
}

// Upper Bound: first index where nums[i] > x
int upperBound(int nums[], int n, int x) {
    int left = 0, right = n - 1;
    int ans = n;  // default if not found

    while (left <= right) {
        int mid = left + (right - left) / 2;

        if (nums[mid] > x) {
            ans = mid;
            right = mid - 1;  // search left side
        } else {
            left = mid + 1;
        }
    }

    return ans;
}

int main() {
    int n;
    scanf("%d", &n);

    int nums[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &nums[i]);
    }

    int x;
    scanf("%d", &x);

    int lb = lowerBound(nums, n, x);
    int ub = upperBound(nums, n, x);

    printf("%d %d\n", lb, ub);

    return 0;
}
