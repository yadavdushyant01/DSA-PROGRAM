#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

// DFS function to detect cycle
bool dfs(int node, int** graph, int* colSize, bool* visited, bool* recStack) {
    visited[node] = true;
    recStack[node] = true;

    for (int i = 0; i < colSize[node]; i++) {
        int neighbor = graph[node][i];

        // If not visited → DFS
        if (!visited[neighbor]) {
            if (dfs(neighbor, graph, colSize, visited, recStack))
                return true;
        }
        // If already in recursion stack → cycle
        else if (recStack[neighbor]) {
            return true;
        }
    }

    // Remove from recursion stack
    recStack[node] = false;
    return false;
}

// Function to detect cycle in graph
bool hasCycle(int V, int** graph, int* colSize) {
    bool* visited = (bool*)calloc(V, sizeof(bool));
    bool* recStack = (bool*)calloc(V, sizeof(bool));

    for (int i = 0; i < V; i++) {
        if (!visited[i]) {
            if (dfs(i, graph, colSize, visited, recStack)) {
                free(visited);
                free(recStack);
                return true;
            }
        }
    }

    free(visited);
    free(recStack);
    return false;
}

// Example usage
int main() {
    int V = 4;

    // Adjacency list
    int* graph[4];
    int colSize[4];

    graph[0] = (int[]){1};
    colSize[0] = 1;

    graph[1] = (int[]){2};
    colSize[1] = 1;

    graph[2] = (int[]){3};
    colSize[2] = 1;

    graph[3] = (int[]){1}; // Creates a cycle
    colSize[3] = 1;

    if (hasCycle(V, graph, colSize))
        printf("YES\n");
    else
        printf("NO\n");

    return 0;
}
