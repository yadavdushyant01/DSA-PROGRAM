#include <stdio.h>
#include <stdlib.h>

#define MAX 1000

int maxLen(int arr[], int n) {
    int prefixSum = 0;
    int maxLength = 0;

    // Simple hash map using arrays (since constraints are small)
    // Initialize all to -2 (means not visited)
    int hash[2 * MAX + 1];
    for (int i = 0; i < 2 * MAX + 1; i++) {
        hash[i] = -2;
    }

    int offset = MAX; // to handle negative sums

    for (int i = 0; i < n; i++) {
        prefixSum += arr[i];

        // Case 1: sum is zero
        if (prefixSum == 0) {
            maxLength = i + 1;
        }

        // Case 2: seen before
        if (hash[prefixSum + offset] != -2) {
            int prevIndex = hash[prefixSum + offset];
            int length = i - prevIndex;
            if (length > maxLength) {
                maxLength = length;
            }
        } else {
            // store first occurrence
            hash[prefixSum + offset] = i;
        }
    }

    return maxLength;
}

int main() {
    int arr[] = {15, -2, 2, -8, 1, 7, 10, 23};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("%d\n", maxLen(arr, n));
    return 0;
}
