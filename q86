#include <stdio.h>

int integerSqrt(int n) {
    if (n < 2) return n;

    int left = 1, right = n / 2;
    int ans = 0;

    while (left <= right) {
        int mid = left + (right - left) / 2;

        // Avoid overflow: use division instead of mid * mid
        if (mid <= n / mid) {
            ans = mid;          // valid candidate
            left = mid + 1;     // try to find a larger one
        } else {
            right = mid - 1;    // too large
        }
    }

    return ans;
}

int main() {
    int n;
    scanf("%d", &n);

    printf("%d\n", integerSqrt(n));

    return 0;
}
