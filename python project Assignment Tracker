import tkinter as tk
from tkinter import ttk, messagebox
from pymongo import MongoClient
import pandas as pd

#DATABASE 
client = MongoClient("mongodb://localhost:27017/")
db = client["assignment_tracker"]
collection = db["assignments"]

current_user = None
current_batch = None
dark_mode = False

#FUNCTION
def login():
    global current_user, current_batch
    if not sap_var.get() or not batch_var.get():
        messagebox.showerror("Error", "Enter all fields")
        return

    current_user = sap_var.get()
    current_batch = batch_var.get()

    login_window.destroy()
    root.deiconify()
    refresh_dashboard()


def add_assignment():
    if not title_var.get() or not deadline_var.get():
        messagebox.showerror("Error", "Fill all fields")
        return

    data = {
        "sap_id": current_user,
        "batch": current_batch,
        "title": title_var.get(),
        "deadline": deadline_var.get(),
        "priority": priority_var.get(),
        "status": "Pending"
    }
    collection.insert_one(data)
    refresh_dashboard()


def refresh_dashboard():
    for row in tree.get_children():
        tree.delete(row)

    data = list(collection.find(
        {"sap_id": current_user, "batch": current_batch}, {"_id": 0}
    ))

    df = pd.DataFrame(data)

    if df.empty:
        completed_label.config(text="Completed: 0")
        pending_label.config(text="Pending: 0")
        progress_bar["value"] = 0
        progress_label.config(text="0% Done")
        return

    for _, row in df.iterrows():
        tree.insert("", tk.END, values=list(row))

    completed = len(df[df["status"] == "Completed"])
    pending = len(df[df["status"] == "Pending"])

    completed_label.config(text=f"Completed: {completed}")
    pending_label.config(text=f"Pending: {pending}")

    progress = int((completed / len(df)) * 100)
    progress_bar["value"] = progress
    progress_label.config(text=f"{progress}% Done")


def mark_complete():
    selected = tree.selection()
    if not selected:
        return

    title = tree.item(selected[0])["values"][2]

    collection.update_one(
        {"sap_id": current_user, "batch": current_batch, "title": title},
        {"$set": {"status": "Completed"}}
    )
    refresh_dashboard()


def delete_assignment():
    selected = tree.selection()
    if not selected:
        return

    title = tree.item(selected[0])["values"][2]

    collection.delete_one(
        {"sap_id": current_user, "batch": current_batch, "title": title}
    )
    refresh_dashboard()


def search_assignment():
    query = search_var.get().lower()

    for row in tree.get_children():
        tree.delete(row)

    data = collection.find(
        {"sap_id": current_user, "batch": current_batch}, {"_id": 0}
    )

    for a in data:
        if query in a["title"].lower():
            tree.insert("", tk.END, values=list(a.values()))


def show_pending_with_deadline():
    data = list(collection.find(
        {"sap_id": current_user, "batch": current_batch, "status": "Pending"},
        {"_id": 0}
    ))

    if not data:
        messagebox.showinfo("Info", "No pending assignments")
        return

    df = pd.DataFrame(data)
    df["deadline"] = pd.to_datetime(df["deadline"], errors='coerce')
    df = df.sort_values(by="deadline")

    win = tk.Toplevel(root)
    win.title("Pending Assignments (By Deadline)")
    win.geometry("700x400")

    tree_pending = ttk.Treeview(win, columns=list(df.columns), show="headings")

    for col in df.columns:
        tree_pending.heading(col, text=col)
        tree_pending.column(col, width=120)

    tree_pending.pack(fill="both", expand=True)

    for _, row in df.iterrows():
        tree_pending.insert("", tk.END, values=list(row))


def toggle_theme():
    global dark_mode
    dark_mode = not dark_mode

    bg = "#1e1e1e" if dark_mode else "#eef2f7"
    root.configure(bg=bg)
    sidebar.configure(bg="#111" if dark_mode else "#2c3e50")


#GUI
root = tk.Tk()
root.title("Smart Dashboard")
root.geometry("1000x600")
root.withdraw()

# Sidebar
sidebar = tk.Frame(root, width=200, bg="#2c3e50")
sidebar.pack(side="left", fill="y")

tk.Label(sidebar, text="Dashboard", fg="white",
         bg="#2c3e50", font=("Arial", 16)).pack(pady=20)

tk.Button(sidebar, text="Toggle Theme", command=toggle_theme).pack(pady=10)

# Main Area
main = tk.Frame(root, bg="#eef2f7")
main.pack(side="right", fill="both", expand=True)

# Top Bar
top = tk.Frame(main, bg="#eef2f7")
top.pack(fill="x", pady=10)

search_var = tk.StringVar()
tk.Entry(top, textvariable=search_var, width=30).pack(side="left", padx=10)
tk.Button(top, text="Search", command=search_assignment).pack(side="left")

# Stats
stats = tk.Frame(main, bg="#eef2f7")
