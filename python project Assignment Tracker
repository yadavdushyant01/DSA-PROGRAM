progress_bar = ttk.Progressbar(stats, length=200)
progress_bar.grid(row=1, column=0, columnspan=2, pady=10)

progress_label = tk.Label(stats, text="0% Done")
progress_label.grid(row=2, column=0, columnspan=2)

#FORM
form = tk.Frame(main, bg="#eef2f7")
form.pack(pady=10)

title_var = tk.StringVar()
deadline_var = tk.StringVar()
priority_var = tk.StringVar(value="Medium")

# Labels
tk.Label(form, text="Subject Name").grid(row=0, column=0, padx=5)
tk.Label(form, text="Date (DD-MM-YYYY)").grid(row=0, column=1, padx=5)
tk.Label(form, text="Priority").grid(row=0, column=2, padx=5)

# Inputs
tk.Entry(form, textvariable=title_var, width=25).grid(row=1, column=0, padx=5, pady=5)
tk.Entry(form, textvariable=deadline_var, width=20).grid(row=1, column=1, padx=5, pady=5)
ttk.Combobox(form, textvariable=priority_var,
             values=["Low", "Medium", "High"], width=15).grid(row=1, column=2, padx=5, pady=5)

# Buttons
tk.Button(form, text="Add", command=add_assignment).grid(row=1, column=3, padx=5)
tk.Button(form, text="Complete", command=mark_complete).grid(row=1, column=4)
tk.Button(form, text="Delete", command=delete_assignment).grid(row=1, column=5)

tk.Button(form, text="Pending (Deadline)",
          command=show_pending_with_deadline,
          bg="#ff9800", fg="white").grid(row=1, column=6, padx=5)

# Table
columns = ("sap_id", "batch", "title", "deadline", "priority", "status")
tree = ttk.Treeview(main, columns=columns, show="headings")

for col in columns:
    tree.heading(col, text=col)
    tree.column(col, width=130)

tree.pack(fill="both", expand=True, padx=10, pady=10)

#LOGIN
login_window = tk.Toplevel()
login_window.title("Login")
login_window.geometry("300x200")

sap_var = tk.StringVar()
batch_var = tk.StringVar()

tk.Label(login_window, text="SAP ID").pack()
tk.Entry(login_window, textvariable=sap_var).pack()

tk.Label(login_window, text="Batch").pack()
tk.Entry(login_window, textvariable=batch_var).pack()

tk.Button(login_window, text="Login", command=login).pack(pady=10)

root.mainloop()
